# PRism environment template — copy to .env and fill in.
# Never commit .env.

## Adobe I/O Runtime credentials (populated by `aio app use` or the Developer Console workspace JSON)
AIO_runtime_auth=''
AIO_runtime_namespace=''
AIO_runtime_apihost='https://adobeioruntime.net'

## GitHub Personal Access Token with `repo` scope (for reading issues + opening PRs)
GITHUB_TOKEN=''

## Comma-separated list of "owner/repo" targets PRism should watch.
## Examples:
##   TARGET_REPOS='adobe/aio-theme'
##   TARGET_REPOS='adobe/aio-theme,adobe/aio-cli-plugin-app-dev'
TARGET_REPOS=''

## Amazon Bedrock — pick ONE auth method:
## (a) Long-term Bedrock API key (recommended). Generate at Bedrock console → API keys.
AWS_BEARER_TOKEN_BEDROCK=''
## (b) IAM user access key / secret (used only if the bearer token is empty)
AWS_ACCESS_KEY_ID=''
AWS_SECRET_ACCESS_KEY=''

## AWS region for Bedrock calls. us-east-1 has the widest Claude availability.
AWS_REGION='us-east-1'

## Bedrock Claude model ID. Examples (region-dependent):
##   us.anthropic.claude-sonnet-4-20250514-v1:0       (Sonnet 4, inference profile)
##   us.anthropic.claude-opus-4-20250514-v1:0         (Opus 4, inference profile)
##   anthropic.claude-3-5-sonnet-20241022-v2:0        (Sonnet 3.5 v2, direct)
BEDROCK_MODEL_ID='us.anthropic.claude-sonnet-4-20250514-v1:0'

## Slack webhook URL for notifications (optional — leave empty to no-op)
SLACK_WEBHOOK_URL=''
