# PRism environment template — copy to .env and fill in.
# Never commit .env.

## Adobe I/O Runtime credentials (populated by `aio app use` or the Developer Console workspace JSON)
AIO_runtime_auth=''
AIO_runtime_namespace=''
AIO_runtime_apihost='https://adobeioruntime.net'

## GitHub Personal Access Token with `repo` scope (for reading issues + opening PRs)
GITHUB_TOKEN=''

## Comma-separated list of "owner/repo" targets PRism should watch.
## Examples:
##   TARGET_REPOS='adobe/aio-theme'
##   TARGET_REPOS='adobe/aio-theme,adobe/aio-cli-plugin-app-dev'
TARGET_REPOS=''

## Anthropic API key (Claude Opus 4.6 by default). Leave empty to fall back to heuristic triage.
ANTHROPIC_API_KEY=''
ANTHROPIC_MODEL='claude-opus-4-6'

## Slack webhook URL for notifications (optional — leave empty to no-op)
SLACK_WEBHOOK_URL=''
